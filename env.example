# ═══════════════════════════════════════════════════════════════
# YAZ Development — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git — keep it in .gitignore.
# In Vercel: add each variable in Project Settings → Environment Variables.
#
# Variables prefixed with PUBLIC_ are exposed to the browser (SvelteKit convention).
# Everything else is server-only and accessed via `$env/static/private`.
# ═══════════════════════════════════════════════════════════════


# ─── DATABASE — Neon PostgreSQL ────────────────────────────────
# Get from: https://console.neon.tech → Project → Connection Details
# Use the POOLED connection string (-pooler in the host) for serverless.
# Channel binding required for Neon serverless driver.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Direct (non-pooled) connection — used only by drizzle-kit for migrations
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"


# ─── AUTH.JS ───────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: https://yazdvs.com/auth/callback/google
#                          http://localhost:5173/auth/callback/google (dev)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated admin email allow-list (granted role='admin' on signIn)
ADMIN_EMAILS="nasr@yazdvs.com,info@yazdv.com"


# ─── TRANSACTIONAL EMAIL — Resend ──────────────────────────────
# https://resend.com/api-keys
# Verify the sending domain (yazdvs.com) in Resend dashboard first.
RESEND_API_KEY=""
RESEND_FROM="YAZ Development <noreply@yazdvs.com>"
RESEND_REPLY_TO="info@yazdv.com"

# Internal notification recipient when a lead/quote arrives
NOTIFY_EMAIL="info@yazdv.com,sales@yazdvs.com"


# ─── MEDIA STORAGE — Vercel Blob ───────────────────────────────
# Vercel Dashboard → Project → Storage → Blob → Create Token (Read/Write)
BLOB_READ_WRITE_TOKEN=""


# ─── RATE LIMITING — Upstash Redis ─────────────────────────────
# https://console.upstash.com → Create Redis database (Regional, closest to Vercel region)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ─── PUBLIC SITE CONFIG ────────────────────────────────────────
# Exposed to the browser — safe to be visible in client bundle.
PUBLIC_SITE_URL="https://yazdvs.com"
PUBLIC_SITE_NAME="YAZ Development"
PUBLIC_WHATSAPP_NUMBER="966553932623"
PUBLIC_CONTACT_PHONE_1="+966553932623"
PUBLIC_CONTACT_PHONE_2="+966539008757"
PUBLIC_CONTACT_EMAIL="info@yazdv.com"
PUBLIC_OFFICE_ADDRESS="King Abdulaziz Road, King Fahd District, Riyadh 12274, Saudi Arabia"

# Default locale: en or ar
PUBLIC_DEFAULT_LOCALE="en"


# ─── SOCIAL LINKS (public) ─────────────────────────────────────
PUBLIC_LINKEDIN_URL="https://www.linkedin.com/company/yaz-development-company/"
PUBLIC_YOUTUBE_URL="https://youtube.com/@yaz_development_survey"
PUBLIC_INSTAGRAM_URL="https://www.instagram.com/yaz.development"
PUBLIC_FACEBOOK_URL="https://www.facebook.com/share/1AfPcEpvpi/"
PUBLIC_TIKTOK_URL=""


# ─── ANALYTICS (optional) ──────────────────────────────────────
# Vercel Analytics — auto-enabled on deployment, no key required.
# Add the @vercel/analytics + @vercel/speed-insights packages.

# Google Analytics 4 (optional)
PUBLIC_GA_MEASUREMENT_ID=""

# PostHog (optional)
PUBLIC_POSTHOG_KEY=""
PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"


# ─── ERROR TRACKING — Sentry (optional) ────────────────────────
PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT="yaz-web"


# ─── STITCH MCP (local dev only — DO NOT add to Vercel) ────────
# Used only by Claude Code / Cursor when generating designs locally.
# This is NOT consumed by the SvelteKit app at runtime.
# Register the MCP server in your shell, not in this file:
#
#   export STITCH_API_KEY="your-google-api-key"
#   claude mcp add stitch \
#     --transport http \
#     --header "X-Goog-Api-Key: $STITCH_API_KEY" \
#     https://stitch.googleapis.com/mcp


# ─── DEV-ONLY FLAGS ────────────────────────────────────────────
# Set to "true" to enable verbose Drizzle query logging in dev.
DRIZZLE_LOG="false"

# Set to "true" to bypass rate limiting in local dev.
RATE_LIMIT_DISABLED="false"


# ═══════════════════════════════════════════════════════════════
# CHECKLIST before going to production
# ═══════════════════════════════════════════════════════════════
#
# [ ] All secrets above filled in (no empty strings remain)
# [ ] AUTH_SECRET generated with `openssl rand -base64 32` (NOT reused from dev)
# [ ] Google OAuth redirect URIs include both prod + dev URLs
# [ ] Resend domain yazdvs.com verified (SPF, DKIM, DMARC records added)
# [ ] Vercel Blob token has Read/Write permissions
# [ ] Upstash Redis database is in the same region as Vercel deployment
# [ ] PUBLIC_SITE_URL matches the actual production domain
# [ ] .env is in .gitignore (run: `git check-ignore .env` — should output `.env`)
# [ ] All env vars added to Vercel: Production, Preview, Development scopes
# [ ] Old leaked secrets (any that appeared in chat/logs/screenshots) rotated
#
# ═══════════════════════════════════════════════════════════════
